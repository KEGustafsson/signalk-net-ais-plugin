{
  "name": "signalk-net-ais-plugin",
  "version": "2.0.0",
  "description": "Marine traffic information is gathered from Finnish Transport Agency’s data sources",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "repository": "https://github.com/KEGustafsson/signalk-net-ais-plugin",
  "author": "Karl-Erik Gustafsson",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
